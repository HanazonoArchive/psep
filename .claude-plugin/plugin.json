{
  "name": "psep",
  "version": "1.0.0",
  "description": "Practical Software Engineering Principles — 7 principles (Scalability, Modularity, Maintainability, Practicality, Straightforward Design, Separation of Concerns, Coding Style) as a controlled reasoning system. Only active during design, review, refactor, and architecture. Never during implementation.",
  "author": {
    "name": "Jay Mark Agsoy (HanazonoArchive)",
    "url": "https://github.com/HanazonoArchive"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/psep-activate.js\" || exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\psep-activate.js\" }",
            "timeout": 5000,
            "statusMessage": "Loading PSEP principles..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/psep-command.js\" || exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\psep-command.js\" }",
            "timeout": 5000,
            "statusMessage": "PSEP command check..."
          }
        ]
      }
    ]
  }
}
